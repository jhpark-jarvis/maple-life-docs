"$schema" = "../node_modules/wrangler/config-schema.json"

name = "docs"
main = "src/entry.py"
compatibility_date = "2026-07-05"
compatibility_flags = ["python_workers"]
workers_dev = true

[observability]
enabled = true

[vars]
R2_PUBLIC_BASE_URL = "https://pub-your-r2-public-host.r2.dev"

[[d1_databases]]
binding = "DB"
database_name = "maple-life-docs"
database_id = "your_d1_database_id"

[[r2_buckets]]
binding = "DOCUMENT_IMAGES"
bucket_name = "your_r2_bucket_name"
