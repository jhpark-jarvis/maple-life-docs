name = "maple-life-docs"
main = "worker/index.js"
compatibility_date = "2026-07-05"

[observability]
enabled = true

[[d1_databases]]
binding = "DB"
database_name = "your-d1-database-name"
database_id = "your-d1-database-id"

[[r2_buckets]]
binding = "DOCUMENT_IMAGES"
bucket_name = "your-r2-bucket-name"

